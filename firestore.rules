rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ALERTS COLLECTION (Temporarily Open for Debugging)
    match /alerts/{alertId} {
      allow read, write: if true; 
    }

    // LEADS COLLECTION
    match /leads/{leadId} {
      allow read: if true;
      allow create, update, delete: if true; // Temporarily open
    }

    // ADMINS COLLECTION
    match /admins/{adminUid} {
      allow read: if true;
      allow write: if false;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow read, write: if true;
    }

    // FCM TOKENS COLLECTION
    match /fcm_tokens/{tokenId} {
      allow read: if true;
      allow write: if true;
    }

    // ASSIGNED BOOKINGS
    match /assigned_bookings/{bookingId} {
      allow read, write: if true; 
    }

    // USER NOTIFICATIONS
    match /user_notifications/{deviceId}/{document=**} {
      allow read, write: if true; 
    }

    // Global Deny (Default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
