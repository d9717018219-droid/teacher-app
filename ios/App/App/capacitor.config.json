{
	"appId": "com.doableindia",
	"appName": "DoAble India",
	"webDir": "dist",
	"server": {
		"hostname": "localhost",
		"allowNavigation": [
			"checkout.razorpay.com",
			"api.razorpay.com"
		]
	},
	"android": {
		"allowMixedContent": true
	},
	"plugins": {
		"GoogleAuth": {
			"scopes": [
				"profile",
				"email"
			],
			"serverClientId": "237759117673-t8sj47mgt7c982rdvjhmqlp5n676o0u8.apps.googleusercontent.com",
			"iosClientId": "237759117673-s9ujpmq5o951otqn207i8b3bnbpiof46.apps.googleusercontent.com",
			"forceCodeForRefreshToken": true
		},
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"CapacitorHttp": {
			"enabled": false
		},
		"CapacitorCookies": {
			"enabled": true
		}
	},
	"packageClassList": [
		"FCMPlugin",
		"GeolocationPlugin",
		"LocalNotificationsPlugin",
		"PushNotificationsPlugin",
		"GoogleAuth"
	]
}
